# LOCAL SIDE QUEST — Environment Variables
# ═══════════════════════════════════════
#
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
#
# In Vercel: Settings → Environment Variables → add these.

# Required: OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here
